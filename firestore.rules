rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function userDocExists(userId) {
      return exists(/databases/$(database)/documents/users/$(userId));
    }

    function userDoc(userId) {
      return get(/databases/$(database)/documents/users/$(userId));
    }

    function isCollaborator(userId) {
      return signedIn()
        && userDocExists(userId)
        && userDoc(userId).data.collaborators is list
        && request.auth.uid in userDoc(userId).data.collaborators;
    }

    function canReadUserData(userId) {
      return isOwner(userId) || isCollaborator(userId);
    }

    function changedKeys() {
      return request.resource.data.diff(resource.data).changedKeys();
    }

    function validShortString(value, maxLen) {
      return value is string && value.size() > 0 && value.size() <= maxLen;
    }

    function validStringList(value, maxItems) {
      return value is list && value.size() <= maxItems;
    }

    function validTransactionType(value) {
      return value == 'income' || value == 'expense';
    }

    function validTimestamp(value) {
      return value is timestamp;
    }

    function validPreferences(value) {
      return value is map
        && value.keys().hasOnly([
          'currency',
          'themeMode',
          'highContrast',
          'emailNotifications',
          'pushNotifications',
          'onboardingComplete'
        ])
        && validShortString(value.currency, 8)
        && (value.themeMode == 'light' || value.themeMode == 'dark')
        && value.highContrast is bool
        && value.emailNotifications is bool
        && value.pushNotifications is bool
        && value.onboardingComplete is bool;
    }

    function validUserProfileCreate() {
      return request.resource.data.keys().hasOnly([
          'email',
          'displayName',
          'collaborators',
          'preferences',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.keys().hasAll([
          'email',
          'displayName',
          'collaborators',
          'preferences',
          'createdAt',
          'updatedAt'
        ])
        && validShortString(request.resource.data.email, 320)
        && validShortString(request.resource.data.displayName, 80)
        && validStringList(request.resource.data.collaborators, 20)
        && validPreferences(request.resource.data.preferences)
        && validTimestamp(request.resource.data.createdAt)
        && validTimestamp(request.resource.data.updatedAt);
    }

    function validUserProfileUpdate() {
      let data = request.resource.data;
      let changes = request.resource.data.diff(resource.data).affectedKeys();
      // Allow both full preferences replacement and dot-notation field updates
      // (preferences.currency, preferences.onboardingComplete, etc.)
      return changes.hasAny(['updatedAt'])
        && validTimestamp(data.updatedAt)
        && (
          !changes.hasAny(['preferences'])
          || validPreferences(data.preferences)
        );
    }

    function validTransactionCreate() {
      let data = request.resource.data;
      let hasRequired = data.keys().hasAll([
        'amount', 'categoryId', 'date', 'description', 'tags', 'type', 'createdAt', 'updatedAt'
      ]);
      let hasOnlyAllowed = data.keys().hasOnly([
        'amount', 'categoryId', 'date', 'description', 'tags', 'type', 'linkedLoanId', 'createdAt', 'updatedAt'
      ]);
      return hasRequired && hasOnlyAllowed
        && data.amount is number && data.amount > 0
        && validShortString(data.categoryId, 64)
        && (data.date is string || data.date is timestamp)
        && validShortString(data.description, 240)
        && validStringList(data.tags, 12)
        && validTransactionType(data.type)
        && (!('linkedLoanId' in data) || validShortString(data.linkedLoanId, 64))
        && validTimestamp(data.createdAt)
        && validTimestamp(data.updatedAt);
    }

    function validTransactionUpdate() {
      let changes = changedKeys();
      let data = request.resource.data;
      return changes.hasOnly([
          'amount', 'categoryId', 'date', 'description', 'tags', 'type', 'linkedLoanId', 'updatedAt'
        ])
        && changes.hasAny(['updatedAt'])
        && validTimestamp(data.updatedAt)
        && (!changes.hasAny(['amount']) || (data.amount is number && data.amount > 0))
        && (!changes.hasAny(['categoryId']) || validShortString(data.categoryId, 64))
        && (!changes.hasAny(['date']) || (data.date is string || data.date is timestamp))
        && (!changes.hasAny(['description']) || validShortString(data.description, 240))
        && (!changes.hasAny(['tags']) || validStringList(data.tags, 12))
        && (!changes.hasAny(['type']) || validTransactionType(data.type))
        && (!changes.hasAny(['linkedLoanId']) || validShortString(data.linkedLoanId, 64));
    }

    function validCategoryCreate() {
      return request.resource.data.keys().hasOnly([
          'name',
          'icon',
          'color',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.keys().hasAll(['name', 'icon', 'color', 'createdAt'])
        && validShortString(request.resource.data.name, 60)
        && validShortString(request.resource.data.icon, 40)
        && validShortString(request.resource.data.color, 32)
        && validTimestamp(request.resource.data.createdAt)
        && (
          !('updatedAt' in request.resource.data)
          || validTimestamp(request.resource.data.updatedAt)
        );
    }

    function validCategoryUpdate() {
      return changedKeys().hasOnly(['name', 'icon', 'color', 'updatedAt'])
        && changedKeys().hasAny(['updatedAt'])
        && validTimestamp(request.resource.data.updatedAt)
        && (
          !changedKeys().hasAny(['name'])
          || validShortString(request.resource.data.name, 60)
        )
        && (
          !changedKeys().hasAny(['icon'])
          || validShortString(request.resource.data.icon, 40)
        )
        && (
          !changedKeys().hasAny(['color'])
          || validShortString(request.resource.data.color, 32)
        );
    }

    function validBudgetCreate() {
      return request.resource.data.keys().hasOnly([
          'categoryId',
          'month',
          'limit',
          'updatedAt'
        ])
        && request.resource.data.keys().hasAll(['categoryId', 'month', 'limit', 'updatedAt'])
        && validShortString(request.resource.data.categoryId, 64)
        && request.resource.data.month is string
        && request.resource.data.month.matches('^[0-9]{4}-[0-9]{2}$')
        && request.resource.data.limit is number
        && request.resource.data.limit > 0
        && validTimestamp(request.resource.data.updatedAt);
    }

    function validBudgetUpdate() {
      return changedKeys().hasOnly(['categoryId', 'month', 'limit', 'updatedAt'])
        && changedKeys().hasAny(['updatedAt'])
        && validTimestamp(request.resource.data.updatedAt)
        && (
          !changedKeys().hasAny(['categoryId'])
          || validShortString(request.resource.data.categoryId, 64)
        )
        && (
          !changedKeys().hasAny(['month'])
          || (
            request.resource.data.month is string
            && request.resource.data.month.matches('^[0-9]{4}-[0-9]{2}$')
          )
        )
        && (
          !changedKeys().hasAny(['limit'])
          || (
            request.resource.data.limit is number
            && request.resource.data.limit > 0
          )
        );
    }

    function validChatMessage() {
      return request.resource.data.keys().hasOnly(['role', 'content', 'timestamp'])
        && (request.resource.data.role == 'user' || request.resource.data.role == 'assistant')
        && validShortString(request.resource.data.content, 5000)
        && validTimestamp(request.resource.data.timestamp);
    }

    function validLoanDirection(value) {
      return value == 'borrowed' || value == 'lent';
    }

    function validLoanStatus(value) {
      return value == 'active' || value == 'settled';
    }

    function validLoanCreate() {
      let data = request.resource.data;
      let hasRequired = data.keys().hasAll([
        'person', 'amount', 'direction', 'status', 'description', 'createdAt', 'updatedAt'
      ]);
      let hasOnlyAllowed = data.keys().hasOnly([
        'person', 'amount', 'repaidAmount', 'direction', 'status', 'description',
        'dueDate', 'settledDate', 'createdAt', 'updatedAt'
      ]);
      return hasRequired && hasOnlyAllowed
        && validShortString(data.person, 120)
        && data.amount is number && data.amount > 0
        && (!('repaidAmount' in data) || (data.repaidAmount is number && data.repaidAmount >= 0))
        && validLoanDirection(data.direction)
        && validLoanStatus(data.status)
        && data.description is string && data.description.size() <= 500
        && validTimestamp(data.createdAt)
        && validTimestamp(data.updatedAt);
    }

    function validLoanUpdate() {
      let changes = changedKeys();
      let data = request.resource.data;
      return changes.hasOnly([
          'person', 'amount', 'repaidAmount', 'direction', 'status', 'description',
          'dueDate', 'settledDate', 'updatedAt'
        ])
        && changes.hasAny(['updatedAt'])
        && validTimestamp(data.updatedAt)
        && (!changes.hasAny(['person']) || validShortString(data.person, 120))
        && (!changes.hasAny(['amount']) || (data.amount is number && data.amount > 0))
        && (!changes.hasAny(['repaidAmount']) || (data.repaidAmount is number && data.repaidAmount >= 0))
        && (!changes.hasAny(['direction']) || validLoanDirection(data.direction))
        && (!changes.hasAny(['status']) || validLoanStatus(data.status));
    }

    function validGoalStatus(value) {
      return value == 'active' || value == 'completed' || value == 'paused';
    }

    function validSavingsGoalCreate() {
      let data = request.resource.data;
      let hasRequired = data.keys().hasAll([
        'name', 'targetAmount', 'currentAmount', 'status', 'createdAt', 'updatedAt'
      ]);
      let hasOnlyAllowed = data.keys().hasOnly([
        'name', 'targetAmount', 'currentAmount', 'status', 'targetDate', 'icon', 'color', 'createdAt', 'updatedAt'
      ]);
      return hasRequired && hasOnlyAllowed
        && validShortString(data.name, 120)
        && data.targetAmount is number && data.targetAmount > 0
        && data.currentAmount is number && data.currentAmount >= 0
        && validGoalStatus(data.status)
        && (!('targetDate' in data) || data.targetDate is string)
        && (!('icon' in data) || validShortString(data.icon, 40))
        && (!('color' in data) || validShortString(data.color, 32))
        && validTimestamp(data.createdAt)
        && validTimestamp(data.updatedAt);
    }

    function validSavingsGoalUpdate() {
      let changes = changedKeys();
      let data = request.resource.data;
      return changes.hasOnly([
          'name', 'targetAmount', 'currentAmount', 'status', 'targetDate', 'icon', 'color', 'updatedAt'
        ])
        && changes.hasAny(['updatedAt'])
        && validTimestamp(data.updatedAt)
        && (!changes.hasAny(['name']) || validShortString(data.name, 120))
        && (!changes.hasAny(['targetAmount']) || (data.targetAmount is number && data.targetAmount > 0))
        && (!changes.hasAny(['currentAmount']) || (data.currentAmount is number && data.currentAmount >= 0))
        && (!changes.hasAny(['status']) || validGoalStatus(data.status))
        && (!changes.hasAny(['targetDate']) || data.targetDate is string)
        && (!changes.hasAny(['icon']) || validShortString(data.icon, 40))
        && (!changes.hasAny(['color']) || validShortString(data.color, 32));
    }

    function validSplitStatus(value) {
      return value == 'pending' || value == 'settled';
    }

    function validSplitExpenseCreate() {
      let data = request.resource.data;
      let hasRequired = data.keys().hasAll([
        'description', 'totalAmount', 'myShare', 'splitWith', 'status', 'createdAt', 'updatedAt'
      ]);
      let hasOnlyAllowed = data.keys().hasOnly([
        'description', 'totalAmount', 'myShare', 'splitWith', 'status', 'linkedTransactionId', 'settledDate', 'createdAt', 'updatedAt'
      ]);
      return hasRequired && hasOnlyAllowed
        && validShortString(data.description, 240)
        && data.totalAmount is number && data.totalAmount > 0
        && data.myShare is number && data.myShare >= 0 && data.myShare <= data.totalAmount
        && validShortString(data.splitWith, 120)
        && validSplitStatus(data.status)
        && (!('linkedTransactionId' in data) || validShortString(data.linkedTransactionId, 64))
        && validTimestamp(data.createdAt)
        && validTimestamp(data.updatedAt);
    }

    function validSplitExpenseUpdate() {
      let changes = changedKeys();
      let data = request.resource.data;
      return changes.hasOnly([
          'description', 'totalAmount', 'myShare', 'splitWith', 'status', 'linkedTransactionId', 'settledDate', 'updatedAt'
        ])
        && changes.hasAny(['updatedAt'])
        && validTimestamp(data.updatedAt)
        && (!changes.hasAny(['description']) || validShortString(data.description, 240))
        && (!changes.hasAny(['totalAmount']) || (data.totalAmount is number && data.totalAmount > 0))
        && (!changes.hasAny(['myShare']) || (data.myShare is number && data.myShare >= 0 && data.myShare <= data.totalAmount))
        && (!changes.hasAny(['splitWith']) || validShortString(data.splitWith, 120))
        && (!changes.hasAny(['status']) || validSplitStatus(data.status))
        && (!changes.hasAny(['linkedTransactionId']) || validShortString(data.linkedTransactionId, 64));
    }

    match /users/{userId} {
      allow create: if isOwner(userId) && validUserProfileCreate();
      allow read: if canReadUserData(userId);
      allow update: if isOwner(userId) && validUserProfileUpdate();
      allow delete: if isOwner(userId);

      match /transactions/{txnId} {
        allow read: if canReadUserData(userId);
        allow create: if canReadUserData(userId) && validTransactionCreate();
        allow update: if canReadUserData(userId) && validTransactionUpdate();
        allow delete: if canReadUserData(userId);
      }

      match /categories/{categoryId} {
        allow read: if canReadUserData(userId);
        allow create: if isOwner(userId) && validCategoryCreate();
        allow update: if isOwner(userId) && validCategoryUpdate();
        allow delete: if isOwner(userId);
      }

      match /budgets/{budgetId} {
        allow read: if canReadUserData(userId);
        allow create: if canReadUserData(userId) && validBudgetCreate();
        allow update: if canReadUserData(userId) && validBudgetUpdate();
        allow delete: if canReadUserData(userId);
      }

      match /loans/{loanId} {
        allow read: if canReadUserData(userId);
        allow create: if isOwner(userId) && validLoanCreate();
        allow update: if isOwner(userId) && validLoanUpdate();
        allow delete: if isOwner(userId);
      }

      match /savingsGoals/{goalId} {
        allow read: if canReadUserData(userId);
        allow create: if canReadUserData(userId) && validSavingsGoalCreate();
        allow update: if canReadUserData(userId) && validSavingsGoalUpdate();
        allow delete: if canReadUserData(userId);
      }

      match /splitExpenses/{splitId} {
        allow read: if canReadUserData(userId);
        allow create: if canReadUserData(userId) && validSplitExpenseCreate();
        allow update: if canReadUserData(userId) && validSplitExpenseUpdate();
        allow delete: if canReadUserData(userId);
      }

      match /chatHistory/{messageId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && validChatMessage();
      }

      match /insights/{insightId} {
        allow read: if canReadUserData(userId);
        allow write: if isOwner(userId);
      }

      match /recurringRules/{ruleId} {
        allow read: if canReadUserData(userId);
        allow create: if isOwner(userId);
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }
    }
  }
}
